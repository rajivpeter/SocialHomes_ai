# SocialHomes.Ai — Server Environment Variables
# Copy this file to .env and fill in the values.

# ---- Server ----
PORT=8080
NODE_ENV=development

# ---- Google Cloud / Firebase ----
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=

# ---- Vertex AI (Gemini) ----
VERTEX_AI_ENABLED=false
VERTEX_AI_PROJECT=
VERTEX_AI_LOCATION=europe-west2

# ---- Claude AI (Anthropic) ----
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ---- File Upload (GCS) ----
GCS_BUCKET=socialhomes-uploads

# ---- EPC Register API ----
EPC_API_KEY=

# ---- Demo Auth ----
DEMO_USER_PASSWORD=
